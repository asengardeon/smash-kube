{
  "name": "smash-kube",
  "version": "1.0.0",
  "description": "Smash Kube - EKS Kubernetes Cluster Viewer",
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently \"npm run watch\" \"electron .\"",
    "watch": "webpack --watch --config webpack.config.js",
    "build": "webpack --config webpack.config.js && electron-builder --publish always",
    "compile": "webpack --config webpack.config.js",
    "test": "jest"
  },
  "keywords": [
    "kubernetes",
    "eks",
    "aws",
    "electron"
  ],
  "author": "Junie",
  "license": "MIT",
  "dependencies": {
    "@kubernetes/client-node": "^0.18.1",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.22.9",
    "@babel/preset-react": "^7.22.5",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "autoprefixer": "^10.4.14",
    "babel-jest": "^29.6.2",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^25.3.0",
    "electron-builder": "^24.4.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.27",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.smashkube.app",
    "publish": [
      {
        "provider": "github",
        "owner": "asengardeon",
        "repo": "smash-kube"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "preload.js",
      "renderer/dist/**/*"
    ],
    "win": {
      "target": "portable",
      "artifactName": "${name}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${name}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "${name}.${ext}"
    }
  }
}
